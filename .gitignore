# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments and local config
.venv/
venv/
env/
.env
.env.*
!.env.example

# macOS and editor files
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs and temporary files
logs/
.pids/
*.log
*.tmp
*.bak

# Local data root. Keep placeholder/sample directories visible while ignoring
# downloaded datasets and runtime uploads.
data/*
!data/raw/
!data/raw/.gitkeep
!data/raw/CIC-IDS2017/
!data/raw/CIC-IDS2017/.gitkeep
!data/samples/
!data/samples/pcap/
!data/samples/csv/
!data/samples/pcap/*.pcap
!data/samples/csv/*.csv

# Gateway local uploads
data/uploads/

# Generated outputs and model artifacts
outputs/
*.joblib
*.pkl
*.pickle
*.pt
*.pth
*.onnx

# Large local datasets
data/raw/CIC-IDS2017/*
!data/raw/CIC-IDS2017/.gitkeep
data/csv/**/*.csv
data/pcap/**/*
*.pcap
*.pcapng
*.cap

# Local cached/sample data can be large; keep it out of Git unless a tiny
# fixture is intentionally added with a more specific negation rule.
data/samples/*.csv

# Local generated debug files
src/debug/
